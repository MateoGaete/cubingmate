# Variables de Entorno - CubingMate Web
# Copia este archivo como .env y reemplaza los valores con tus credenciales reales

# Mercado Pago - Credenciales de PRODUCCION
# ObtÃ©n tus credenciales en: https://www.mercadopago.cl/developers/panel/credentials
# Public Key: Se usa para operaciones del frontend (opcional)
# Access Token: Se usa para crear preferencias de pago (requerido)
# Para pruebas usa tokens que comiencen con TEST-
# Para producciÃ³n usa tokens que comiencen con APP_USR-
VITE_MERCADO_PAGO_PUBLIC_KEY=TU_PUBLIC_KEY_AQUI
VITE_MERCADO_PAGO_ACCESS_TOKEN=TU_ACCESS_TOKEN_AQUI

# Mercado Pago - ID de Aplicacion (opcional)
MERCADO_PAGO_APP_ID=TU_APP_ID_AQUI

# Mercado Pago Webhook Secret
# Obtener desde: https://www.mercadopago.cl/developers/panel/app/{tu-app-id}/webhooks
# Este secret se usa para validar que las notificaciones vienen de Mercado Pago
# IMPORTANTE: Configura esto despuÃ©s de crear el webhook en el panel de Mercado Pago
MERCADO_PAGO_WEBHOOK_SECRET=TU_WEBHOOK_SECRET_AQUI

# Mercado Pago - Clave adicional (si es necesaria)
MERCADO_PAGO_SECRET_KEY=TU_SECRET_KEY_AQUI

# Puerto del servidor webhook (opcional, por defecto 3001)
WEBHOOK_PORT=3001

# Firebase Configuration
# ObtÃ©n estos valores en: https://console.firebase.google.com/
# Ve a ConfiguraciÃ³n del proyecto > Tus aplicaciones > Web
VITE_FIREBASE_API_KEY=tu-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
VITE_FIREBASE_APP_ID=tu-app-id